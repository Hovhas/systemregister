# === Databas ===
DATABASE_URL=postgresql+asyncpg://systemregister:devpassword@db:5432/systemregister
DATABASE_URL_SYNC=postgresql://systemregister:devpassword@db:5432/systemregister
TEST_DATABASE_URL=postgresql+asyncpg://systemregister:devpassword@db:5432/systemregister_test

# === Säkerhet ===
SECRET_KEY=change-me-in-production-use-32-byte-random-hex
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Auth (OIDC, bakom feature flag) ===
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
OIDC_ORG_CLAIM=org_id
OIDC_ROLES_CLAIM=groups
OIDC_SUPERADMIN_ROLE=systemregister_admin

# === Metakatalog (bakom feature flag) ===
METAKATALOG_ENABLED=false
METAKATALOG_BASE_URL=
METAKATALOG_API_KEY=
METAKATALOG_WEBHOOK_SECRET=

# === Rate limiting ===
RATE_LIMIT_DEFAULT=200/minute

# === Logging ===
LOG_LEVEL=INFO

# === CORS / Proxy ===
TRUSTED_PROXY_HOSTS=*

# === Dokploy (endast i .env.local — ALDRIG committa värden) ===
# Panel-URL och API-token för driftsättning via scripts/dokploy/dokploy.sh
DOKPLOY_URL=https://panel.sundsvall.dev
DOKPLOY_EMAIL=
DOKPLOY_API_TOKEN=
# Applikationens ID i Dokploy (hämtas en gång med: scripts/dokploy/dokploy.sh apps <project-id>)
DOKPLOY_APP_ID=
